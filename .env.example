# Foundry controller configuration — copy to .env and fill in.
# The real .env is gitignored (.env, .env.*); this example is committed.
# Values here are PLACEHOLDERS, never real secrets.

# --- Required ---

# MySQL DSN for the foundry database.
DATABASE_URL=mysql://foundry:CHANGEME@127.0.0.1/foundry

# AES-256-GCM key for secrets at rest: base64 of 32 random bytes.
# Generate with: openssl rand -base64 32
FOUNDRY_ENCRYPTION_KEY=replace-me-base64-of-32-random-bytes

# --- Optional (defaults shown) ---

# Bind address for the controller HTTP server.
FOUNDRY_BIND=127.0.0.1:8400

# sqlx connection pool size.
FOUNDRY_DB_MAX_CONNECTIONS=10

# Public origin (used in OAuth redirect URLs); trailing slash trimmed.
FOUNDRY_PUBLIC_URL=https://foundry.example.com

# Wildcard domain for published apps; lower-cased, dots trimmed.
# Unset disables HTTP/S app publishing.
# FOUNDRY_APPS_DOMAIN=apps.example.com

# Comma-separated emails granted admin on first GitLab login.
# FOUNDRY_ADMIN_EMAILS=admin@example.com,ops@example.com

# --- Logging (optional) ---

# Set to `json` for structured journald logs (default: pretty/plain).
# FOUNDRY_LOG_FORMAT=json
# tracing env-filter directive.
# RUST_LOG=info
