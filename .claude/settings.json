{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(node -p \"require\\('./frontend/package.json'\\).version\")",
      "Bash(echo \"versions: $\\(grep -m1 '^version' Cargo.toml\\) / frontend $\\(node -p \"require\\('./frontend/package.json'\\).version\"\\)\")",
      "Bash(scripts/deploy.sh)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(./scripts/deploy.sh)",
      "Bash(git push *)",
      "Bash(grep -rniE \"\\(password|passwd|secret|token|api_key|apikey|private_key|credential\\)\\\\s*[:=]\\\\s*[\\\\\"'][^\\\\\"'{}$]{6,}\" /opt/foundry/controller /opt/foundry/agent /opt/foundry/shared /opt/foundry/frontend/src)",
      "Bash(sort -t: -k2 -rn)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/doc-drift-check.sh"
          }
        ]
      }
    ]
  }
}
